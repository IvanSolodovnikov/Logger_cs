<Window x:Class="LogManagerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Manager" Height="400" Width="600">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Список логов" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Таблица логов -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Messages}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}"/>
                <DataGridTextColumn Header="Дата/Время" Binding="{Binding DateTime}"/>
                <DataGridTextColumn Header="Текст" Binding="{Binding Text}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопка сохранения -->
        <Button Grid.Row="2" Content="Сохранить в файл" HorizontalAlignment="Right" Width="120" Margin="0,10,0,0"
                Click="SaveButton_Click"/>
    </Grid>
</Window>