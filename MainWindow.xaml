<Window x:Class="LogManagerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logger" Height="450" Width="800">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Button Content="Добавить лог"
                Height="30"
                Click="AddLog_Click"/>

        <ListBox x:Name="Logs"
                 Grid.Row="1"/>

    </Grid>

</Window>