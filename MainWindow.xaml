<Window x:Class="LogManagerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logger" Height="450" Width="800">

    <Grid>

        <StackPanel Orientation="Horizontal" Height="40">

            <Button Content="Info"
                    Click="Info_Click"
                    Width="80"
                    Margin="5"/>

            <Button Content="Warning"
                    Click="Warning_Click"
                    Width="80"
                    Margin="5"/>

            <Button Content="Error"
                    Click="Error_Click"
                    Width="80"
                    Margin="5"/>

            <Button Content="Save"
                    Click="Save_Click"
                    Width="80"
                    Margin="5"/>

        </StackPanel>

        <ListBox ItemsSource="{Binding Logs}"
                 Margin="0,40,0,0"/>

    </Grid>

</Window>